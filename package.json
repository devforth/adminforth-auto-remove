{
  "name": "@adminforth/auto-remove",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "homepage": "https://adminforth.dev/docs/tutorial/Plugins/auto-remove/",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && rsync -av --exclude 'node_modules' custom dist/"
  },
  "keywords": [
    "adminforth",
    "data-retention",
    "record-cleanup",
    "ttl",
    "pruning",
    "housekeeping",
    "record-expiration"
  ],
  "author": "",
  "license": "MIT",
  "description": "Automatic record cleanup plugin for AdminForth with age-based and count-based retention rules",
  "devDependencies": {
    "@types/node": "latest",
    "adminforth": "^2.42.0",
    "semantic-release": "^24.2.1",
    "semantic-release-slack-bot": "^4.0.2",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "adminforth": "^2.42.0"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "semantic-release-slack-bot",
        {
          "packageName": "@adminforth/auto-remove",
          "notifyOnSuccess": true,
          "notifyOnFail": true,
          "slackIcon": ":package:",
          "markdownReleaseNotes": true
        }
      ]
    ],
    "branches": [
      "main",
      {
        "name": "next",
        "prerelease": true
      }
    ]
  }
}
